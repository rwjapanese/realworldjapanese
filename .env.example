# Copy to .env (local dev) and set the same keys in Cloudflare Pages → Settings → Environment variables (production).
# すべて optional。未設定なら該当タグは出力されません。

# Google Search Console verification tag
# GSC「別のHTMLメタタグを追加」で発行される content="..." の値だけを貼る
PUBLIC_GOOGLE_SITE_VERIFICATION=

# Google Analytics 4 Measurement ID (G-XXXXXXXXXX)
# GA4 → 管理 → データ ストリーム → ウェブ の「測定 ID」
PUBLIC_GA_MEASUREMENT_ID=
